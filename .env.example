# FidelityBench runs without API keys using deterministic local agents.
# LLM agents are optional.

# Recommended LLM baseline provider
ANTHROPIC_API_KEY=

# Also supported
OPENAI_API_KEY=

# Advanced / optional Bedrock support, if configured in this repo
BEDROCK_API_KEY=
BEDROCK_AWS_REGION=
AWS_BEARER_TOKEN_BEDROCK=

# Provider override: anthropic | openai | bedrock
FIDELITYBENCH_PROVIDER=

# Model override
# Suggested Anthropic: claude-sonnet-4-5 or current Sonnet equivalent
# Suggested OpenAI: gpt-4.1 or current strong reasoning/chat model
FIDELITYBENCH_MODEL=

# Debugging / benchmark controls
FIDELITYBENCH_DEBUG=
FIDELITYBENCH_TURN_LIMIT=

# WindowedTranscriptLLMAgent controls
FIDELITYBENCH_TRANSCRIPT_WINDOW_CHARS=12000
FIDELITYBENCH_TRANSCRIPT_WINDOW_MESSAGES=

# External stdio agent integration
FIDELITYBENCH_EXTERNAL_AGENT=
FIDELITYBENCH_EXTERNAL_AGENT_NAME=
FIDELITYBENCH_EXTERNAL_AGENT_TIMEOUT_MS=
